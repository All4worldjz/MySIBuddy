{
  "name": "gemini-proxy",
  "version": "1.0.0",
  "description": "OpenAI-compatible proxy for Google Gemini via OAuth authentication",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "build": "esbuild src/index.js --bundle --platform=node --format=esm --outfile=dist/bundle.js --minify",
    "start:prod": "node dist/bundle.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "esbuild": "^0.20.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
