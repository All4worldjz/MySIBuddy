# Gemini OAuth Credentials (JSON from ~/.gemini/oauth_creds.json)
# If not set, will automatically load from ~/.gemini/oauth_creds.json
# GCP_SERVICE_ACCOUNT={"access_token":"...","refresh_token":"...","scope":"...","token_type":"Bearer","id_token":"...","expiry_date":...}

# Optional: Google Cloud Project ID (auto-discovered if not set)
# GEMINI_PROJECT_ID=your-project-id

# Optional: API key for authentication (if not set, API is public)
# Clients must include "Authorization: Bearer <your-api-key>" header
OPENAI_API_KEY=sk-your-secret-api-key-here

# Optional: Enable real Gemini thinking output
ENABLE_REAL_THINKING=false

# Optional: Enable fake thinking output (synthetic reasoning)
ENABLE_FAKE_THINKING=false

# Server port (default: 8787)
PORT=8787
