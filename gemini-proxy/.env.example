# Gemini Proxy 环境变量配置

# 服务端口 (默认: 8787)
PORT=8787

# OAuth 凭证 JSON 字符串 (可选，优先级高于 ~/.gemini/oauth_creds.json)
# GCP_SERVICE_ACCOUNT={"access_token":"...","refresh_token":"...","scope":"...","token_type":"Bearer","id_token":"...","expiry_date":...}

# GCP 项目 ID (可选，自动发现)
# GEMINI_PROJECT_ID=your-project-id

# API Key 验证 (可选)
# OPENAI_API_KEY=sk-your-api-key

# 思考输出配置
ENABLE_REAL_THINKING=false
ENABLE_FAKE_THINKING=false