# Wiki Monitor 环境变量配置
# 复制此文件为 .env 并填入实际值

# ===== 飞书配置 =====
FEISHU_APP_ID=cli_your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_KM_VAULT_TOKEN=your_km_vault_token
FEISHU_BASE_URL=https://open.feishu.cn/open-apis

# ===== GitHub 配置 =====
GITHUB_SSH_KEY=~/.ssh/id_ed25519
GITHUB_REPO=git@github.com:All4worldjz/MySiBuddy-Wiki.git
GITHUB_BRANCH=main

# ===== Wiki 路径配置 =====
WIKI_LOCAL_PATH=~/.openclaw/wiki/main
WIKI_RAW_DIR=raw/articles
WIKI_WIKI_DIR=wiki
WIKI_EXPORT_FOLDER_NAME=Wiki 知识库镜像

# ===== 日志配置 =====
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_FILES=10
LOG_MAX_SIZE=10m

# ===== 监控器配置 =====
MONITOR_ENABLED=true
MONITOR_DRY_RUN=false
MONITOR_NOTIFY_ON_COMPLETE=false
MONITOR_NOTIFY_ON_ERROR=true

# ===== Telegram 通知（可选）=====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
