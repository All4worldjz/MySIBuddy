# 知识库编译服务 - 环境变量模板
# 复制为 .env 并填写实际值

# OpenClaw 认证
OPENCLAW_API_URL=http://localhost:8000
OPENCLAW_AGENT_ID=coder-hub

# 飞书配置
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_VAULT_FOLDER_TOKEN=QB50fa4HYlYPCRd5Q8Cck6MMnvf

# 编译模型（默认 minimax/MiniMax-M2.7）
LLM_MODEL=minimax/MiniMax-M2.7

# 日志级别（debug/info/warning/error）
LOG_LEVEL=info

# Docker 卷挂载配置（本地运行时）
# -v /path/to/KM_Vault:/app/vault
